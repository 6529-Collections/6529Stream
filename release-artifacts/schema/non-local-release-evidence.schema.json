{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/6529-Collections/6529Stream/main/release-artifacts/schema/non-local-release-evidence.schema.json",
  "title": "6529Stream Non-Local Release Evidence Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "record_type",
    "review_status",
    "environment",
    "chain_id",
    "block_or_reference",
    "command_or_source_system",
    "retained_path",
    "sha256",
    "redaction_statement",
    "owner",
    "reviewer",
    "public_beta_requirement_id",
    "source",
    "redaction_policy",
    "template_notice",
    "operator_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "6529stream.non-local-release-evidence.v1"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "record_type": {
      "enum": ["template", "evidence"]
    },
    "review_status": {
      "enum": ["template", "pending_review", "reviewed"]
    },
    "environment": {
      "enum": ["fork", "testnet", "live", "audit", "release_signing"]
    },
    "chain_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "const": "not_applicable"
        }
      ]
    },
    "block_or_reference": {
      "type": "string",
      "minLength": 1
    },
    "command_or_source_system": {
      "type": "string",
      "minLength": 1
    },
    "retained_path": {
      "$ref": "#/$defs/repo_path"
    },
    "sha256": {
      "$ref": "#/$defs/sha256"
    },
    "redaction_statement": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "public_beta_requirement_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "git_commit", "source_dirty", "ci_run"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "source_dirty": {
          "type": "boolean"
        },
        "ci_run": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_secrets", "redacted_fields"],
      "properties": {
        "no_secrets": {
          "const": true
        },
        "redacted_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "template_notice": {
      "type": "string",
      "minLength": 1
    },
    "operator_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "\\\\"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
