{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "https://json-schema.org/draft/2020-12/schema",
  "title": "6529Stream Risk Register",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "maturity",
    "readiness_boundary",
    "source_documents",
    "status_taxonomy",
    "risk_acceptance_policy",
    "risks",
    "redaction_policy",
    "operator_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "6529stream.risk-register.v1"
    },
    "generated_by": {
      "type": "string"
    },
    "maturity": {
      "type": "string"
    },
    "readiness_boundary": {
      "type": "string"
    },
    "source_documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file_ref"
      }
    },
    "status_taxonomy": {
      "type": "object"
    },
    "risk_acceptance_policy": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "redaction_policy": {
      "type": "object"
    },
    "operator_notes": {
      "type": "string"
    }
  },
  "$defs": {
    "file_ref": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "required": [
        "id",
        "title",
        "area",
        "severity",
        "status",
        "owner",
        "target_gate",
        "source",
        "mitigation",
        "residual_risk",
        "evidence",
        "checks",
        "tracking",
        "risk_acceptance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^RISK-[A-Z0-9]+-[0-9]{3}$"
        },
        "title": {
          "type": "string"
        },
        "area": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "target_gate": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "mitigation": {
          "type": "string"
        },
        "residual_risk": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_ref"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tracking": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_acceptance": {
          "type": ["object", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
