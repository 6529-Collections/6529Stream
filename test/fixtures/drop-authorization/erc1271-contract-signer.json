  "failure_cases": [
    {
      "id": "wrong_signer",
      "expected_revert": "Bad contract sig",
      "notes": "The signer contract must be the active tdhSigner and must approve the same digest."
    },
    {
      "id": "wrong_domain",
      "expected_revert": "Bad contract sig",
      "notes": "A contract signer should reject a digest generated for a different domain."
    },
    {
      "id": "expired",
      "expected_revert": "Expired",
      "notes": "ERC-1271 approval does not bypass deadline validation."
    },
    {
      "id": "replayed_or_consumed",
      "expected_revert": "Drop Executed",
      "notes": "Replay protection remains StreamDrops storage, not contract-signer memory."
    },
    {
      "id": "stale_signer_epoch",
      "expected_revert": "Bad epoch",
      "notes": "Epoch rotation invalidates contract-signer payloads exactly like EOA payloads."
    },
    {
      "id": "bad_drop_id",
      "expected_revert": "Bad dropId",
      "notes": "The drop ID must derive from the contract signer address, signerEpoch, nonce, and salt."
    },
    {
      "id": "erc1271_invalid_magic",
      "expected_revert": "Bad contract sig",
      "notes": "Invalid magic values, empty returns, short returns, long returns, reverts, wrong digests, and wrong bytes fail closed."
    },
    {
      "id": "zero_address",
      "expected_revert": "Zero recipient",
      "notes": "The same zero-address validation applies after ERC-1271 approval."
    }
  ]
}
