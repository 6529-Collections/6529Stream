    {
      "id": "wrong_domain",
      "expected_revert": "Wrong signer",
      "notes": "Auction authorizations are bound to chainId and verifyingContract."
    },
    {
      "id": "expired",
      "expected_revert": "Expired",
      "notes": "deadline is independent from auctionEndTime and must still be live when mintDrop executes."
