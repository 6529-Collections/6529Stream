    {
      "id": "replayed_or_consumed",
      "expected_revert": "Drop Executed",
      "notes": "The auction drop ID is consumed before auction registration side effects complete."
    },
    {
      "id": "cancelled_drop",
      "expected_revert": "Drop cancelled",
      "notes": "Cancelled auction authorizations fail before the NFT is minted to auction custody."
    },
    {
      "id": "bad_drop_id",
      "expected_revert": "Bad dropId",
      "notes": "Auction drop IDs are derived from signer, signerEpoch, nonce, and salt."
    },
    {
      "id": "token_data_substitution",
      "expected_revert": "Token data",
      "notes": "The auction tokenData string is part of the signed payload through tokenDataHash."
