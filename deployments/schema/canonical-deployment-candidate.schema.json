{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/6529-Collections/6529Stream/main/deployments/schema/canonical-deployment-candidate.schema.json",
  "title": "6529Stream Canonical Deployment Candidate",
  "description": "Version 1 is deliberately limited to non-production tooling fixtures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "candidate_kind",
    "production_candidate",
    "readiness_evidence",
    "network",
    "release_build",
    "instances"
  ],
  "properties": {
    "schema_version": {
      "const": "6529stream.canonical-deployment-candidate.v1"
    },
    "candidate_id": {
      "$ref": "#/$defs/identifier"
    },
    "candidate_kind": {
      "const": "non_production_fixture"
    },
    "production_candidate": {
      "const": false
    },
    "readiness_evidence": {
      "const": false
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "chain_id"],
      "properties": {
        "environment": {
          "enum": ["anvil", "local", "fork", "testnet"]
        },
        "chain_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      }
    },
    "release_build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_path",
        "receipt_sha256",
        "target_catalog_sha256",
        "config_path",
        "config_sha256",
        "foundry_config_path",
        "foundry_config_sha256"
      ],
      "properties": {
        "receipt_path": {
          "const": "out-release/release-build-manifest.json"
        },
        "receipt_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "target_catalog_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "config_path": {
          "const": "release-artifacts/contracts.json"
        },
        "config_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "foundry_config_path": {
          "const": "foundry.toml"
        },
        "foundry_config_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "instances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/instance"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "solidity_name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*:)(?!.*\\\\)(?!.*//)(?!\\.\\.?(?:/|$))(?!.*(?:/\\.\\.?(?:/|$)))(?!.*\\/$).+$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$",
      "not": {
        "const": "0x0000000000000000000000000000000000000000"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "keccak256": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "hex_bytes": {
      "type": "string",
      "pattern": "^0x(?:[0-9a-fA-F]{2})+$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name",
        "source",
        "artifact_relative_path",
        "artifact_sha256"
      ],
      "properties": {
        "kind": {
          "const": "production_contract"
        },
        "name": {
          "$ref": "#/$defs/solidity_name"
        },
        "source": {
          "$ref": "#/$defs/repo_path"
        },
        "artifact_relative_path": {
          "$ref": "#/$defs/repo_path"
        },
        "artifact_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "constructor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "types",
        "arguments",
        "encoded_args_keccak256"
      ],
      "properties": {
        "types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "arguments": {
          "type": "array",
          "items": {}
        },
        "encoded_args_keccak256": {
          "$ref": "#/$defs/keccak256"
        }
      }
    },
    "library": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "name", "address"],
      "properties": {
        "source": {
          "$ref": "#/$defs/repo_path"
        },
        "name": {
          "$ref": "#/$defs/solidity_name"
        },
        "address": {
          "$ref": "#/$defs/address"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["immutable_values", "expected_keccak256"],
      "properties": {
        "immutable_values": {
          "type": "object",
          "propertyNames": {
            "pattern": "^(?:0|[1-9][0-9]*)$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/hex_bytes"
          }
        },
        "expected_keccak256": {
          "$ref": "#/$defs/keccak256"
        }
      }
    },
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "instance_id",
        "profile_entry_id",
        "target",
        "depends_on",
        "constructor",
        "libraries",
        "runtime",
        "expected_initcode_keccak256"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "instance_id": {
          "$ref": "#/$defs/identifier"
        },
        "profile_entry_id": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "constructor": {
          "$ref": "#/$defs/constructor"
        },
        "libraries": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/library"
          }
        },
        "runtime": {
          "$ref": "#/$defs/runtime"
        },
        "expected_initcode_keccak256": {
          "$ref": "#/$defs/keccak256"
        }
      }
    }
  }
}
