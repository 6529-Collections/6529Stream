        "constructor_args": [
          "$DEPLOYED_STREAM_CORE",
          "$DEPLOYED_STREAM_ADMINS",
          "0x0000000000000000000000000000000000000000"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "StreamDrops",
        "address": "0x0000000000000000000000000000000000000006",
        "constructor_args": [
          "$SEPOLIA_DROP_SIGNER",
          "$DEPLOYED_STREAM_MINTER",
          "$DEPLOYED_STREAM_ADMINS",
          "$SEPOLIA_PAYOUT",
          "$DEPLOYED_STREAM_CURATORS_POOL"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "StreamAuctions",
        "address": "0x0000000000000000000000000000000000000007",
        "constructor_args": [
          "$DEPLOYED_STREAM_MINTER",
          "$DEPLOYED_STREAM_CORE",
          "$DEPLOYED_STREAM_ADMINS",
          "$DEPLOYED_STREAM_DROPS",
          "$SEPOLIA_PAYOUT",
          "$DEPLOYED_STREAM_CURATORS_POOL"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "NextGenRandomizerVRF",
        "address": "0x0000000000000000000000000000000000000008",
        "constructor_args": [
          "$SEPOLIA_VRF_SUBSCRIPTION_ID",
          "$SEPOLIA_VRF_COORDINATOR",
          "$DEPLOYED_STREAM_CORE",
          "$DEPLOYED_STREAM_ADMINS"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "NextGenRandomizerRNG",
        "address": "0x0000000000000000000000000000000000000009",
        "constructor_args": [
