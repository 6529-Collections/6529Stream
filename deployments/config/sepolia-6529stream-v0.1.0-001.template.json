          "$DEPLOYED_STREAM_ADMINS",
          "$SEPOLIA_ARRNG_CONTROLLER"
        ],
        "verification_status": "not_started"
      }
    ],
    "admin_ceremony": {
      "deployer": "$SEPOLIA_DEPLOYER_ADDRESS",
      "admin_safe": "$SEPOLIA_ADMIN_SAFE",
      "emergency_recipient": "$SEPOLIA_EMERGENCY_RECIPIENT",
      "pause_guardians": [
        "$SEPOLIA_PAUSE_GUARDIAN"
      ],
      "unpause_admins": [
        "$SEPOLIA_ADMIN_SAFE"
      ],
      "signer_managers": [
        "$SEPOLIA_ADMIN_SAFE"
      ],
      "drop_signers": [
        "$SEPOLIA_DROP_SIGNER"
      ],
      "temporary_admins_revoked": true,
      "ownership_transfers": [
        {
          "contract": "StreamAdmins",
          "new_owner": "$SEPOLIA_ADMIN_SAFE"
        },
        {
          "contract": "StreamCore",
          "new_owner": "$SEPOLIA_ADMIN_SAFE"
        }
      ]
    },
    "external_dependencies": {
      "vrf_coordinator": "$SEPOLIA_VRF_COORDINATOR",
      "arrng_controller": "$SEPOLIA_ARRNG_CONTROLLER",
      "delegation_registry": "$SEPOLIA_DELEGATION_REGISTRY"
    },
    "verification": {
      "contract_verification": "not_started",
      "constructor_args_retained": false,
      "commands": [
        "forge script script/RehearseDeployment.s.sol:RehearseDeployment --sig \"runSepolia()\" --rpc-url <redacted> --broadcast --verify --via-ir"
      ]
    },
    "release_artifacts": {
      "event_topic_catalog": "release-artifacts/latest/event-topic-catalog.json"
    },
    "rehearsal": {
      "command": "forge script script/RehearseDeployment.s.sol:RehearseDeployment --sig \"runSepolia()\" --rpc-url <redacted> --sender <deployer> <approved Foundry signer flags redacted> --broadcast --verify --via-ir",
      "anvil_passed": false,
      "fork_passed": false,
      "testnet_passed": false,
      "notes": "Template only. Replace placeholders with reviewed Sepolia broadcast outputs before generating a manifest or claiming public-beta evidence."
    }
  }
}
