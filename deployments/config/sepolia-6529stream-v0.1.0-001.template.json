{
  "schema_version": "6529stream.deployment-manifest-input.v1",
  "template_notice": "Template only. Copy this file to a non-template Sepolia config after a real reviewed broadcast replaces every placeholder address, transaction reference, and command transcript. Do not commit RPC endpoint values, signing secrets, API tokens, raw signatures, or unreleased drop payloads.",
  "operator_runbook": "docs/deployment.md#sepolia-deployment-rehearsal-runbook",
  "operator_inputs": {
    "script_entrypoint": "script/RehearseDeployment.s.sol:RehearseDeployment --sig \"runSepolia()\"",
    "required_environment_variables": [
      {
        "name": "SEPOLIA_RPC_URL",
        "retained_value": "redacted",
        "purpose": "Sepolia RPC endpoint used by the operator shell only."
      },
      {
        "name": "SEPOLIA_CONTRACT_METADATA_URI",
        "retained_value": "public_uri",
        "purpose": "Reviewed contract-level metadata URI for the ERC-7572-style adapter constructor."
      },
      {
        "name": "SEPOLIA_DEPLOYER_ADDRESS",
        "retained_value": "public_address",
        "purpose": "Public Forge broadcaster address matching the approved hardware, keystore, cloud, or CI signing backend."
      },
      {
        "name": "SEPOLIA_ADMIN_SAFE",
        "retained_value": "public_address",
        "purpose": "Safe or multisig that receives ownership/admin authority."
      },
      {
        "name": "SEPOLIA_PAUSE_GUARDIAN",
        "retained_value": "public_address",
        "purpose": "Address authorized for pause controls."
      },
      {
        "name": "SEPOLIA_EMERGENCY_RECIPIENT",
        "retained_value": "public_address",
        "purpose": "Address authorized to receive emergency withdrawals where permitted."
      },
      {
        "name": "SEPOLIA_DROP_SIGNER",
        "retained_value": "public_address",
        "purpose": "Approved drop authorization signer address."
      },
      {
        "name": "SEPOLIA_PAYOUT",
        "retained_value": "public_address",
        "purpose": "Poster/protocol payout recipient used by deployment rehearsal drops and auctions."
      },
      {
        "name": "SEPOLIA_DELEGATION_REGISTRY",
        "retained_value": "public_address",
        "purpose": "Delegation registry dependency for curator pool constructor args."
      },
      {
        "name": "SEPOLIA_VRF_COORDINATOR",
        "retained_value": "public_address",
        "purpose": "Sepolia VRF coordinator dependency."
      },
      {
        "name": "SEPOLIA_ARRNG_CONTROLLER",
        "retained_value": "public_address",
        "purpose": "Sepolia arRNG controller dependency."
      },
      {
        "name": "SEPOLIA_VRF_SUBSCRIPTION_ID",
        "retained_value": "public_number",
        "purpose": "VRF subscription or billing identifier used by the rehearsal."
      },
      {
        "name": "ETHERSCAN_API_KEY",
        "retained_value": "redacted",
        "purpose": "Explorer verification token used by the operator shell only."
      }
    ],
    "redaction_policy": {
      "retain_public_addresses": true,
      "retain_transaction_hashes": true,
      "retain_chain_id_and_block": true,
      "redact_rpc_endpoint_values": true,
      "redact_signer_material": true,
      "redact_api_tokens": true,
      "redact_raw_signatures": true,
      "redact_unreleased_drop_payloads": true
    }
  },
  "output": "deployments/examples/sepolia-6529stream-v0.1.0-001.json",
  "manifest": {
    "protocol_version": "0.1.0",
    "deployment_version": "sepolia-6529stream-v0.1.0-001",
    "lifecycle_state": "Template",
    "network": {
      "name": "sepolia",
      "chain_id": 11155111,
      "rpc_environment_variable": "SEPOLIA_RPC_URL",
      "confirmation_depth": 12
    },
    "git": {
      "repository": "https://github.com/6529-Collections/6529Stream",
      "commit": "0000000000000000000000000000000000000000",
      "source_dirty": false
    },
    "toolchain": {
      "foundry_version": "v1.7.1",
      "solidity_version": "0.8.19",
      "profile": "default",
      "optimizer": true,
      "optimizer_runs": 200,
      "via_ir": true
    },
    "contracts": [
      {
        "name": "StreamAdmins",
        "address": "0x0000000000000000000000000000000000000001",
        "constructor_args": [
          "$SEPOLIA_DROP_SIGNER"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "DependencyRegistry",
        "address": "0x0000000000000000000000000000000000000002",
        "constructor_args": [
          "$DEPLOYED_STREAM_ADMINS"
        ],
        "verification_status": "not_started"
      },
      {
        "name": "StreamCore",
        "address": "0x0000000000000000000000000000000000000003",
        "constructor_args": [
          "6529 Stream",
